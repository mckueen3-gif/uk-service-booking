generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String              @id @default(cuid())
  name                 String?
  email                String              @unique
  emailVerified        DateTime?
  image                String?
  password             String?
  role                 Role                @default(CUSTOMER)
  phone                String?
  city                 String?
  addressLine1         String?
  addressLine2         String?
  postcode             String?
  referralCode         String?             @unique
  referralCredits      Float               @default(0)
  stripeCustomerId     String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  mfaEnabled           Boolean             @default(false)
  mfaSecret            String?
  notificationSettings Json?               @default("{\"sms\": false, \"push\": true, \"email\": true}")
  houseNumber          String?
  aiMemory             String?
  dailyAiLimitUsed     Int                 @default(0)
  lastAiUsageDate      DateTime?
  bookings             Booking[]
  conversations        Conversation[]      @relation("CustomerConversations")
  creditTransactions   CreditTransaction[]
  educationAttempts    EducationAttempt[]
  educationQuizzes     EducationQuiz[]
  merchantProfile      Merchant?
  notifications        Notification[]
  properties           Property[]
  redemptionRequests   RedemptionRequest[]
  referralReceived     Referral?           @relation("Referee")
  referralsMade        Referral[]          @relation("Referrer")
  reviews              Review[]
  vehicles             Vehicle[]
  favorites            Merchant[]          @relation("UserFavorites")

  @@index([city])
}

model EducationQuiz {
  id         String              @id @default(cuid())
  userId     String
  title      String
  subject    String
  grade      String?
  difficulty String?
  sourceType String              @default("TEXT")
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  attempts   EducationAttempt[]
  questions  EducationQuestion[]
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EducationQuestion {
  id            String        @id @default(cuid())
  quizId        String
  questionText  String
  questionType  String        @default("MCQ")
  options       Json?
  correctAnswer String
  explanation   String?
  quiz          EducationQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model EducationAttempt {
  id                   String        @id @default(cuid())
  quizId               String
  userId               String
  score                Int
  totalQuestions       Int
  answers              Json
  aiDiagnosis          String?
  createdAt            DateTime      @default(now())
  sharedWithMerchantId String?
  quiz                 EducationQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  sharedWith           Merchant?     @relation("SharedAttempts", fields: [sharedWithMerchantId], references: [id])
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@index([userId])
  @@index([sharedWithMerchantId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO")
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model Vehicle {
  id          String    @id @default(cuid())
  userId      String
  make        String
  model       String
  year        String
  reg         String?
  motDate     DateTime?
  lastService DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Property {
  id        String   @id @default(cuid())
  userId    String
  address   String
  type      String
  boilerAge Int?
  roofType  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Merchant {
  id                 String                 @id @default(cuid())
  userId             String                 @unique
  companyName        String
  description        String?
  registrationNumber String?
  licenseUrl         String?
  isVerified         Boolean                @default(false)
  city               String
  latitude           Float?
  longitude          Float?
  stripeAccountId    String?
  averageRating      Float                  @default(0.0)
  totalReviews       Int                    @default(0)
  completedJobsCount Int                    @default(0)
  commissionRate     Float                  @default(0.09)
  freeOrdersLeft     Int                    @default(0)
  avatarUrl          String?
  bankSortCode       String?
  bankAccountNumber  String?
  slotDuration       Int                    @default(60)
  maxDailyBookings   Int                    @default(8)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  isAccountingActive Boolean                @default(false)
  insuranceAmount    Float?
  memberSince        DateTime               @default(now())
  offersFreeQuotes   Boolean                @default(true)
  ownerName          String?
  vettingChecks      Json?
  businessType       String?
  vatNumber          String?
  bannerUrl          String?
  aiKnowledgeBase    String?
  youtubeVideoUrl    String?
  baseHourlyRate     Float?
  isElite            Boolean                @default(false)
  isTrialAvailable   Boolean                @default(false)
  isSocialPro        Boolean                @default(false)
  socialCreditsUsed  Int                    @default(0)
  lastSocialReset    DateTime?
  pricingPackages    Json?
  trialPrice         Float?
  bookings           Booking[]
  conversations      Conversation[]         @relation("MerchantConversations")
  sharedAttempts     EducationAttempt[]     @relation("SharedAttempts")
  user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  availability       MerchantAvailability[]
  documents          MerchantDocument[]
  portfolio          MerchantPortfolio[]
  scheduleSlots      MerchantScheduleSlot[]
  wallet             MerchantWallet?
  reviews            Review[]
  services           Service[]
  withdrawals        WithdrawalRequest[]
  favoredBy          User[]                 @relation("UserFavorites")

  @@index([city])
  @@index([isVerified])
}

model PlatformSettings {
  id                    String   @id @default("global")
  defaultCommissionRate Float    @default(0.09)
  updatedAt             DateTime @updatedAt
  companyName           String   @default("ConciergeAI UK")
  companyRegistration   String   @default("12345678")
  contactEmail          String   @default("support@conciergeai.uk")
  contactPhone          String   @default("+44 20 1234 5678")
  facebookUrl           String   @default("https://facebook.com/conciergeai")
  instagramUrl          String   @default("https://instagram.com/conciergeai")
  linkedinUrl           String   @default("https://linkedin.com/company/conciergeai")
  officeAddress         String   @default("London, UK")
  twitterUrl            String   @default("https://twitter.com/conciergeai")
  vatRegistration       String   @default("GB123456789")
}

model MarketTrend {
  id        String   @id @default(cuid())
  category  String
  avgPrice  Float
  month     Int
  year      Int
  updatedAt DateTime @updatedAt

  @@unique([category, month, year])
}

model PromoCode {
  id          String    @id @default(cuid())
  code        String    @unique
  maxUses     Int?
  currentUses Int       @default(0)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([code])
}

model MerchantPortfolio {
  id          String   @id @default(cuid())
  merchantId  String
  title       String
  description String?
  imageUrl    String
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  merchant    Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
}

model MerchantDocument {
  id                 String         @id @default(cuid())
  merchantId         String
  type               DocumentType
  fileUrl            String
  status             DocumentStatus @default(PENDING)
  registrationNumber String?
  expiryDate         DateTime?
  aiAnalysis         String?
  confidence         Float?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  merchant           Merchant       @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
}

model MerchantWallet {
  id                String   @id @default(cuid())
  merchantId        String   @unique
  totalEarned       Float    @default(0.0)
  availableBalance  Float    @default(0.0)
  pendingBalance    Float    @default(0.0)
  authorizedBalance Float    @default(0.0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  merchant          Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model WithdrawalRequest {
  id               String   @id @default(cuid())
  merchantId       String
  amount           Float
  status           String   @default("PENDING")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  stripeTransferId String?
  adminNotes       String?  @default("")
  merchant         Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model MerchantAvailability {
  id         String   @id @default(cuid())
  merchantId String
  dayOfWeek  Int
  startTime  String   @default("09:00")
  endTime    String   @default("17:00")
  isOpen     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([merchantId, dayOfWeek])
}

model Service {
  id                           String        @id @default(cuid())
  merchantId                   String
  category                     String
  name                         String
  description                  String?
  price                        Float
  teachingMode                 TeachingMode?
  subjects                     String?
  aiMatchScore                 Float?
  createdAt                    DateTime      @default(now())
  updatedAt                    DateTime      @updatedAt
  emergencyResponseTime        String?
  emergencySurchargePercentage Float         @default(0)
  isEmergencyAble              Boolean       @default(false)
  isTrial                      Boolean       @default(false)
  bookings                     Booking[]
  merchant                     Merchant      @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([merchantId])
}

model Booking {
  id                    String        @id @default(cuid())
  customerId            String
  merchantId            String
  serviceId             String
  scheduledDate         DateTime
  status                BookingStatus @default(PENDING)
  totalAmount           Float
  platformFee           Float         @default(0)
  merchantAmount        Float         @default(0)
  stripePaymentIntentId String?       @unique
  isEducation           Boolean       @default(false)
  depositPaid           Float         @default(0)
  balanceAmount         Float         @default(0)
  stripeBalanceIntentId String?       @unique
  reauthDeadline        DateTime?
  coolingOffUntil       DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  vehicleReg            String?
  vehicleMake           String?
  vehicleModel          String?
  vehicleYear           String?
  vehicleNotes          String?
  isUrgent              Boolean       @default(false)
  googleMeetLink        String?
  customer              User          @relation(fields: [customerId], references: [id])
  merchant              Merchant      @relation(fields: [merchantId], references: [id])
  service               Service       @relation(fields: [serviceId], references: [id])
  dispute               Dispute?
  payment               Payment?
  review                Review?
  variations            Variation[]
  receipt               Receipt?

  @@index([customerId])
  @@index([merchantId])
  @@index([status])
  @@index([scheduledDate])
}

model Variation {
  id          String          @id @default(cuid())
  bookingId   String
  amount      Float
  description String
  photoUrl    String
  status      VariationStatus @default(PENDING)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  booking     Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model Payment {
  id                    String        @id @default(cuid())
  bookingId             String        @unique
  stripePaymentIntentId String        @unique
  amount                Float
  platformFee           Float
  merchantPayout        Float
  status                PaymentStatus @default(PENDING)
  stripeTransferId      String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  booking               Booking       @relation(fields: [bookingId], references: [id])
}

model Review {
  id                  String   @id @default(cuid())
  bookingId           String   @unique
  customerId          String
  merchantId          String
  rating              Int
  comment             String?
  sentiment           String?
  keywords            String?
  reply               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  communicationRating Int?
  qualityRating       Int?
  reliabilityRating   Int?
  booking             Booking  @relation(fields: [bookingId], references: [id])
  customer            User     @relation(fields: [customerId], references: [id])
  merchant            Merchant @relation(fields: [merchantId], references: [id])

  @@index([merchantId])
  @@index([customerId])
}

model Dispute {
  id          String             @id @default(cuid())
  bookingId   String             @unique
  openedById  String
  reason      String
  status      DisputeStatus      @default(OPEN)
  aiDecision  ResolutionDecision @default(PENDING)
  aiReasoning String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  booking     Booking            @relation(fields: [bookingId], references: [id])
  evidence    Evidence[]

  @@index([bookingId])
}

model Evidence {
  id           String   @id @default(cuid())
  disputeId    String
  uploadedById String
  fileUrl      String
  type         String
  description  String?
  createdAt    DateTime @default(now())
  dispute      Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
}

model Receipt {
  id               String   @id @default(cuid())
  bookingId        String   @unique
  fileUrl          String
  receiptNumber    String   @unique
  totalAmount      Float
  taxAmount        Float    @default(0)
  createdAt        DateTime @default(now())
  booking          Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([receiptNumber])
}

model Referral {
  id                String   @id @default(cuid())
  referrerId        String
  refereeId         String   @unique
  status            String   @default("PENDING")
  earnedFromReferee Float    @default(0)
  createdAt         DateTime @default(now())
  referee           User     @relation("Referee", fields: [refereeId], references: [id])
  referrer          User     @relation("Referrer", fields: [referrerId], references: [id])
}

model CreditTransaction {
  id          String          @id @default(cuid())
  userId      String
  amount      Float
  type        TransactionType
  description String?
  bookingId   String?
  createdAt   DateTime        @default(now())
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model Voucher {
  id         String    @id @default(cuid())
  code       String    @unique
  value      Float
  isRedeemed Boolean   @default(false)
  redeemedBy String?
  expiryDate DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([code])
}

model RedemptionRequest {
  id          String    @id @default(cuid())
  userId      String
  amount      Float
  brandName   String?
  status      String    @default("PENDING")
  voucherCode String?
  adminNotes  String?
  issuedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Conversation {
  id            String    @id @default(cuid())
  customerId    String
  merchantId    String
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  customer      User      @relation("CustomerConversations", fields: [customerId], references: [id])
  merchant      Merchant  @relation("MerchantConversations", fields: [merchantId], references: [id])
  messages      Message[]

  @@unique([customerId, merchantId])
  @@index([customerId])
  @@index([merchantId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  imageUrl       String?
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
}

model AiDiagnosis {
  id                  String   @id @default(cuid())
  userId              String?
  imageUrl            String
  category            String
  issue               String
  suggestedFix        String
  estimatedPriceRange String
  confidence          Float
  rawAIResponse       String?
  createdAt           DateTime @default(now())

  @@index([userId])
  @@index([category])
}

model MerchantScheduleSlot {
  id            String   @id @default(cuid())
  merchantId    String
  date          DateTime
  startTime     String
  endTime       String
  isAvailable   Boolean  @default(true)
  createdAt     DateTime @default(now())
  customerName  String?
  customerPhone String?
  notes         String?
  title         String?
  merchant      Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId, date])
}

model BlogPost {
  id         String   @id @default(cuid())
  slug       String   @unique
  title      String
  content    String
  excerpt    String?
  coverImage String?
  published  Boolean  @default(false)
  authorName String   @default("ConciergeAI Team")
  category   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([slug])
  @@index([category])
}

enum Role {
  CUSTOMER
  MERCHANT
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  HELD
  TRANSFERRED
  REFUNDED
}

enum VariationStatus {
  PENDING
  APPROVED
  REJECTED
  DISPUTED
}

enum DisputeStatus {
  OPEN
  REVIEWING
  RESOLVED
}

enum ResolutionDecision {
  PENDING
  REFUND_CUSTOMER
  FORCE_PAYOUT
  SPLIT_COST
  ESCALATE_TO_HUMAN
}

enum DocumentType {
  GAS_SAFE
  NICEIC
  PUBLIC_LIABILITY
  BUSINESS_LICENSE
  SIA_LICENSE
  FOOD_HYGIENE
  CQC_REG
  DVLA_CPC
  DBS_CHECK
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  UNDER_ADMIN_REVIEW
}

enum TeachingMode {
  ONLINE
  OFFLINE
  HYBRID
}

enum TransactionType {
  EARNED_REFERRAL
  SPENT_BOOKING
  VOUCHER_REDEEM
  ADMIN_ADJUSTMENT
  REDEMPTION_VOUCHER
}
